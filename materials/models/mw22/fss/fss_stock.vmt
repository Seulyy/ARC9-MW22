"VertexLitGeneric"
{
    "$basetexture" "models/mw22/fss/fss_stock_rgb"
    "$bumpmap" "models/mw22/fss/fss_stock_n"
    "$phongexponenttexture" "models/mw22/fss/fss_stock_e"

    /////////////////
    "$color2" "[1 1 1]"                                     //do not touch this
    "$blendtintbybasealpha" "1"                             //do not touch this
    /////////////////

    "$phong" "1"
    "$phongboost" "1"
    "$phongalbedotint" "1"
    "$phongalbedoboost" "10"                                //toy around with this
    "$phongfresnelranges" "[1 0.1 0]"		// "[0.32 0.72 0.99]"

	"$phongwarptexture"                 "models\cod2019\shared\steelwarp"

    /////////////////
    "$normalmapalphaenvmapmask" "1"                         //do not touch this
    /////////////////

    "$envmap" "env_cubemap"
    "$envmaptint" "[0.102 0.102 0.102]"

    "$detailblendmode" "4"
    "$detailblendfactor" "0.7"

    //remove this if not using MWB
    "Proxies"
    {
        "Arc9EnvMapTint"
        {
            "specularity" "0.5"
            "min" "0"
            "max" "0.2"
            "color" "[0.106 0.102 0.102]"
        }
        "CustomCamo" 
        {
	"camoTexture" $detail
	"camoScale" $detailscale
	"blend" $detailblendfactor
	"color2" "[0.8 0.8 0.8]"
        }
    }
}